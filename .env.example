# Server Configuration
PORT=8080
NODE_ENV=development

# Platform Integration
# This token is used for BOTH:
# 1. JWT verification (platform signs JWTs with this token)
# 2. API authentication (when fetching user credentials from platform)
PLATFORM_URL=https://agentbase.me
PLATFORM_SERVICE_TOKEN=your-service-token-here

# CORS Configuration
CORS_ORIGIN=https://agentbase.me

# SSH Credentials Configuration
# Users must configure these in agentbase.me integration settings
# The integration should store these fields per user:
# - ssh_host: Remote machine hostname or IP
# - ssh_port: SSH port (default: 22)
# - ssh_username: SSH username
# - ssh_private_key: SSH private key (PEM format)
#
# Example integration configuration in agentbase.me:
# {
#   "ssh_host": "remote.example.com",
#   "ssh_port": 22,
#   "ssh_username": "user",
#   "ssh_private_key": "-----BEGIN OPENSSH PRIVATE KEY-----\n..."
# }
